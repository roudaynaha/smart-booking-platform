{
  "name": "z-schema",
  "version": "12.2.0",
  "description": "Fast, lightweight JSON Schema validator for Node.js and browsers — full support for draft-04, draft-06, draft-07, draft-2019-09, and draft-2020-12 (latest)",
  "keywords": [
    "draft-04",
    "draft-06",
    "draft-07",
    "draft-2019-09",
    "draft-2020-12",
    "esm",
    "json",
    "json-schema",
    "json-schema-validator",
    "jsonschema",
    "schema",
    "typescript",
    "validation",
    "validator"
  ],
  "homepage": "https://github.com/zaggino/z-schema",
  "bugs": {
    "url": "https://github.com/zaggino/z-schema/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zaggino/z-schema.git"
  },
  "bin": {
    "z-schema": "bin/z-schema"
  },
  "files": [
    "bin/",
    "cjs/",
    "dist/",
    "src/",
    "umd/",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "./dist/z-schema-versions.mjs"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./cjs/index.d.ts",
        "default": "./cjs/index.js"
      },
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "prepare": "husky",
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run build && npm run build:tests",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "clean": "rimraf ./cjs && rimraf ./dist && rimraf ./umd && rimraf --glob \"./src/schemas/*.json\"",
    "build": "npm run copy:schemas && tsdown",
    "build:watch": "npm run copy:schemas && tsdown --watch",
    "build:tests": "tsc --noEmit --project test/tsconfig.json",
    "copy:schemas": "node ./scripts/copy-schemas.mts",
    "coverage:artifacts": "node ./scripts/generate-test-coverage-report.mts",
    "coverage:update-badge": "node ./scripts/update-readme-coverage-badge.mts",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:node": "vitest run --project node --silent=false",
    "test:browser": "vitest run --project browser --silent=false",
    "test:sample": "npx vitest run --silent=false --hideSkippedTests --project node -t \"draft6/exclusiveMinimum.json\""
  },
  "dependencies": {
    "punycode": "^2.3.1",
    "safe-regex2": "^5.1.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "^25.2.0",
    "@types/punycode": "^2.1.4",
    "@types/validator": "^13.15.10",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lodash.isequal": "^4.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rimraf": "^6.1.2",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "commander": "^14.0.3"
  },
  "overrides": {
    "vite": ">=7.3.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "authors": [
    "Martin Zagora <zaggino@gmail.com>"
  ]
}
